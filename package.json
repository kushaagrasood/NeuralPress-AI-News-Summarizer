{
  "name": "neuralpress",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,vite -c cyan,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "cd server && node --watch index.js",
    "build": "vite build",
    "preview": "vite preview",
    "start:server": "cd server && node index.js",
    "build:prod": "vite build && cross-env NODE_ENV=production node server/index.js",
    "start:prod": "cross-env NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "vite": "^5.4.2"
  }
}